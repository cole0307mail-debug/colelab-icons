{
  "name": "root",
  "private": true,
  "packageManager": "pnpm@10.6.5",
  "license": "MIT",
  "scripts": {
    "bootstrap": "pnpm generate:core && pnpm build:core",
    "start": "concurrently -n react,vue -c cyan,magenta \"pnpm start:react\" \"pnpm start:vue\"",
    "site": "pnpm site:react && pnpm site:vue",
    "preview": "dumi preview",
    "clean": "rimraf ./**/node_modules",
    "generate": "pnpm -r --workspace-concurrency=1 run generate",
    "generate:core": "pnpm -r --filter @colelab/icons-svg run generate",
    "build:core": "pnpm -r --filter @colelab/icons-svg run build",
    "release": "walrus release",
    "release:build": "lerna run --concurrency 8 --no-private build",
    "release:version": "lerna version --conventional-commits --yes --no-private",
    "release:publish": "pnpm publish --recursive --tag latest",
    "prepare": "husky || true",
    "preinstall": "npx only-allow pnpm",
    "generate:vue": "pnpm --filter @colelab/icons-vue run generate",
    "build:vue": "pnpm --filter @colelab/icons-vue run build",
    "generate:react": "pnpm --filter @colelab/icons-react run generate",
    "build:react": "pnpm --filter @colelab/icons-react run build",
    "build": "pnpm build:core && pnpm build:react && pnpm build:vue",
    "generate:all": "pnpm generate:core && pnpm generate:react && pnpm generate:vue",
    "start:react": "dumi dev",
    "start:vue": "vitepress dev docs-vue",
    "site:react": "dumi build",
    "site:vue": "vitepress build docs-vue",
    "preview:vue": "vitepress preview docs-vue",
    "test:smoke": "node ./tests/smoke-check.mjs",
    "test": "pnpm test:smoke",
    "ci:check": "pnpm generate && pnpm build && pnpm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sensoro-design/sensoro-design-icons.git"
  },
  "bugs": {
    "url": "https://github.com/sensoro-design/sensoro-design-icons/issues"
  },
  "homepage": "https://sen-icons.xingkang.wang",
  "devDependencies": {
    "@commitlint/cli": "catalog:",
    "@commitlint/config-conventional": "catalog:",
    "@pansy/shared": "catalog:",
    "@rgrove/parse-xml": "catalog:",
    "@colelab/icons-react": "workspace:*",
    "@colelab/icons-svg": "workspace:*",
    "@colelab/icons-vue": "workspace:*",
    "@types/gulp": "catalog:",
    "@types/gulp-concat": "catalog:",
    "@types/gulp-header": "catalog:",
    "@types/gulp-rename": "catalog:",
    "@types/lodash": "catalog:",
    "@types/ramda": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/svgo": "catalog:",
    "@types/through2": "catalog:",
    "@types/vinyl": "catalog:",
    "@umijs/utils": "catalog:",
    "@vueuse/core": "^12.7.0",
    "antd": "catalog:",
    "chalk": "catalog:",
    "cross-spawn": "catalog:",
    "del": "catalog:",
    "dumi": "catalog:",
    "father": "catalog:",
    "gulp": "catalog:",
    "gulp-concat": "catalog:",
    "gulp-header": "catalog:",
    "gulp-rename": "catalog:",
    "husky": "catalog:",
    "lerna": "catalog:",
    "lint-staged": "catalog:",
    "lodash": "catalog:",
    "prettier": "catalog:",
    "ramda": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "rimraf": "catalog:",
    "signale": "catalog:",
    "simple-git": "catalog:",
    "svgo": "catalog:",
    "through2": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "use-clipboard-hook": "catalog:",
    "vinyl": "catalog:",
    "vitepress": "^1.6.3",
    "walrus": "workspace:*",
    "zx": "catalog:",
    "concurrently": "^9.1.2"
  },
  "lint-staged": {
    "*.{js,jsx,less,md,json}": [
      "prettier --write"
    ],
    "*.ts?(x)": [
      "prettier --parser=typescript --write"
    ]
  }
}
